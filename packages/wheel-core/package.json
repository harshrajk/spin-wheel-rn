{
  "name": "spin-wheel-core",
  "version": "0.1.0",
  "description": "Pure spin wheel logic for deterministic winner selection and rotation planning.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
