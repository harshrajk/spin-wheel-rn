{
  "name": "@acme/wheel-react-native",
  "version": "0.1.0",
  "description": "React Native spin wheel component for iOS and Android.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react,react-native,react-native-reanimated,react-native-gesture-handler,react-native-svg,@acme/wheel-core",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "react-native",
    "spin-wheel",
    "ios",
    "android"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "react-native-gesture-handler": ">=2.15.0",
    "react-native-reanimated": ">=3.6.0",
    "react-native-svg": ">=15.0.0"
  },
  "dependencies": {
    "@acme/wheel-core": "0.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-native": "^0.73.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
