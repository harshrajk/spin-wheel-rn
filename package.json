{
  "name": "spin-wheel-react-native",
  "version": "0.1.1",
  "description": "React Native spin wheel component for iOS and Android.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.ts",
      "module": "./dist/index.js",
      "default": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react,react-native,react-native-reanimated,react-native-gesture-handler,react-native-svg --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "npm start -w examples/expo-demo"
  },
  "keywords": [
    "react-native",
    "spin-wheel",
    "roulette",
    "ios",
    "android"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "react-native-gesture-handler": ">=2.15.0",
    "react-native-reanimated": ">=3.6.0",
    "react-native-svg": ">=15.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-native": "^0.73.0",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "react-native-gesture-handler": "^2.18.0",
    "react-native-reanimated": "^3.15.1",
    "react-native-svg": "^15.8.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.1"
  }
}
